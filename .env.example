# Copie ce fichier vers `.env` et adapte les valeurs.

# Clé secrète Flask (OBLIGATOIRE en prod). Génère-en une avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-please-use-a-long-random-hex

# Mode : development | production
FLASK_ENV=development

# Pour activer les commandes `flask db ...`
FLASK_APP=app:create_app

# ----- Base de données ------------------------------------------------------
# Laisser vide en dev → SQLite local (chronicle.db).
# En prod : PostgreSQL obligatoire.
#
# Format : postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
# (les URL "postgres://..." de Heroku/Render sont normalisées automatiquement)
DATABASE_URL=
# Exemple local Docker :
# DATABASE_URL=postgresql+psycopg2://chronicle:chronicle@localhost:5432/chronicle
