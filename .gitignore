# Fichiers uploadés par les utilisateurs en local (hors static/uploads/.gitkeep)
# On garde le dossier mais pas les fichiers dynamiques si besoin ; ici on versionne
# les images de démo mais pas les uploads de prod.
static/uploads/images/*.jpg
static/uploads/images/*.jpeg
static/uploads/images/*.png
static/uploads/images/*.gif
static/uploads/images/*.webp
static/uploads/media/*
static/uploads/pdf/*
static/uploads/pdfs/*
static/uploads/authors/*

# On garde les .gitkeep pour préserver la structure des dossiers
!static/uploads/images/.gitkeep
!static/uploads/media/.gitkeep
!static/uploads/pdf/.gitkeep
!static/uploads/pdfs/.gitkeep
!static/uploads/authors/.gitkeep

